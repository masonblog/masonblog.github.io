{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "masonblog",
  "compatibility_date": "2026-05-17",
  "assets": {
    "directory": "./public",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "routes": [
    {
      "pattern": "blog.masonhu.cc",
      "custom_domain": true
    }
  ]
}
